<table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif;">
    <tr>
        <td style="padding-bottom: 10px; margin-bottom: 20px; border-bottom: 2px solid #eee;">
            <h2 style="color: #1a73e8; margin: 0; font-size: 24px;">
                Listing Moderation: "{{listing.title}}"
            </h2>
            <span style="color: #888; font-size: 14px;">
                ID: {{listing._id}} | User ID: {{listing.userId}} | Published: {{listing.publishedAt}}
            </span>
        </td>
    </tr>

    <tr>
        <td style="height: 20px;"></td>
    </tr>

    <tr>
        <td style="padding: 15px; border-radius: 6px; border: 1px solid {{#if moderation.isProfanity}}#f5c6cb{{else}}#bee5eb{{/if}}; background-color: {{#if moderation.isProfanity}}#f8d7da{{else}}#d1ecf1{{/if}};">
            <h3 style="margin-top: 0; margin-bottom: 10px; color: {{#if moderation.isProfanity}}#721c24{{else}}#0c5460{{/if}};">
                Profanity Check
            </h3>
            <p style="margin: 0; font-size: 16px; color: #333;">
                Status: <strong style="color: {{#if moderation.isProfanity}}#721c24{{else}}#0c5460{{/if}};">
                {{#if moderation.isProfanity}}FLAGGED (Profanity Found){{else}}CLEAN{{/if}}
            </strong><br>
                Attempts: {{moderation.profanityCheckAttempts}} / {{moderation.maxAttempts}}
            </p>
        </td>
    </tr>
</table>