<table style="width: 100%; border-collapse: collapse; border: 0;">
    <tr>
        <td style="text-align: center; padding: 20px 0;">
            <h1 style="text-align: center; font-family: Arial, sans-serif; color: #ffffff; margin: 20px 0;">
                Missing Car Reported
            </h1>
            <p style="font-family: Arial, sans-serif; color: #666666; margin-bottom: 10px;">
                A user reported a missing car in the database:
            </p>

            <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 auto 25px auto; background-color: #f8f9fa; border: 1px solid #eeeeee; border-radius: 8px;">
                <tr>
                    <td style="padding: 15px; text-align: left; font-family: Arial, sans-serif;">
                        <p style="font-size: 16px; margin: 5px 0; color: #333333;">
                            <strong>User:</strong> {{firstName}} {{lastName}}.
                        </p>
                        <p style="font-size: 14px; margin: 5px 0; color: #888888;">
                            <strong>ID:</strong> {{userId}}
                        </p>
                        <div style="height: 1px; background-color: #eeeeee; margin: 10px 0;"></div>
                        {{#if model}}
                        <p style="font-size: 16px; margin: 5px 0; color: #333333;">
                            <strong>Current Make:</strong> {{make}}
                        </p>
                        <p style="font-size: 16px; margin: 5px 0; color: #333333;">
                            <strong>Missing Model:</strong> {{model}}
                        </p>
                        {{else}}
                            <p style="font-size: 16px; margin: 5px 0; color: #333333;">
                                <strong>Missing Make:</strong> {{make}}
                            </p>
                        {{/if}}
                    </td>
                </tr>
            </table>

            <table style="margin: 0 auto; border-collapse: collapse; border: 0;">
                <tr>
                    <td style="background-color: #0275d8; border-radius: 5px; text-align: center;">
                        <a href="{{adminUrl}}" style="display: inline-block; padding: 12px 24px; color: #ffffff; text-decoration: none; font-family: Arial, sans-serif; font-weight: bold;">
                            Go to Admin Panel
                        </a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>