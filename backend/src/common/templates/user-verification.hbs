<table style="width: 100%; border-collapse: collapse; border: 0;">
    <tr>
        <td style="text-align: center; padding: 20px 0;">
            <h1 style="text-align: center; font-family: Arial, sans-serif; color: #333333; margin: 20px 0;">
               Verify your email
            </h1>
            <p style="font-family: Arial, sans-serif; color: #666666; margin-bottom: 25px;">
                Click the button below to verify email.
            </p>

            <p style="margin-top: 20px; color: black;">
                <b>For testing (Copy Token):</b><br>
                <code style="display: block; max-width: 300px; margin: 10px auto;   color: white;background: gray; padding: 10px; word-break: break-all;">
                    {{token}}
                </code>
            </p>

            <table style="margin: 0 auto; border-collapse: collapse; border: 0;">
                <tr>
                    <td style="background-color: #007bff; border-radius: 5px; text-align: center;">
                        <a href=`{{link}}` style="display: inline-block; padding: 12px 24px; color: #ffffff; text-decoration: none; font-family: Arial, sans-serif; font-weight: bold;">
                            Go to verify email
                        </a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>