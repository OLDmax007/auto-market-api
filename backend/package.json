{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/main.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "rimraf dist && tsc-watch --onSuccess \"npm run watch:server\"",
    "watch:server": "tsx src/main.ts --watch",
    "seed": "tsx scripts/main-seed.ts",
    "docker:up-all": "docker-compose up --build",
    "docker:up-backend": "docker-compose up backend",
    "docker:run-seeder": "docker-compose run --rm seeder",
    "docker:down": "docker-compose down"
  },
