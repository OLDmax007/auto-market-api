    "cron": "^4.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "handlebars": "^4.7.8",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "leo-profanity": "^1.9.0",
    "lodash": "^4.17.23",
    "mongoose": "^9.0.0",
    "mongoose-paginate-v2": "^1.9.1",
    "node-cache": "^5.1.2",
